---
import Text from "@components/atoms/text.astro"
import Tag from "@components/atoms/tag.astro"
import Button from "@components/atoms/button.astro"

export interface Props {
	title: string
	id: string
	tags: string[]
	description: string
	role: string
	credits: string[]
	url: string
	year: number
}

const {
	id = "",
	title = "",
	tags = [],
	description = "",
	role = "",
	credits = [],
	url = "",
	year = 0,
} = Astro.props
---

<article>
	<header id={id} class="p-md bg-gray-900 text-gray-300 rounded-md">
		<div
			class="mb-md md:mb-xsm flex flex-col md:flex-row items-start md:items-center justify-between gap-tiny"
		>
			<div class="flex flex-wrap gap-tiny shrink-0">
				{
					tags.map((tag) => (
						<Tag variant="gray-300" class="shrink-0" tag="p">
							{tag}
						</Tag>
					))
				}
			</div>
			<hr class="hidden md:block w-full border-gray-400" />
			<Text variant="tag">
				{year}
			</Text>
		</div>
		<Text variant="tlg" class="mb-xsm md:mb-sm">
			{title}
		</Text>
		<Text variant="pmd" class="mb-giant">{description}</Text>
		<div
			class="flex flex-col items-start md:flex-row md:items-end justify-between gap-sm md:gap-md"
		>
			<Text variant="bmd" class="italic">
				<span class="font-700">Rôle :</span>
				{role}
				{
					credits.length > 0 && (
						<>
							<br />
							<span class="font-700">Crédits : </span>
							{credits.map((item) => (
								<>
									<br />
									<span>{item}</span>
								</>
							))}
						</>
					)
				}
			</Text>
			{
				url && (
					<Button
						variant="primary-gray-300"
						attributes={{ target: "_blank" }}
						icon="arrow"
						href={url}
						class="shrink-0"
					>
						Voir le projet
					</Button>
				)
			}
		</div>
	</header>
</article>
