---
import Text from '@components/atoms/text.astro'
import Grid from '@components/organisms/grid.astro'
export interface Props {
  title?: string;
  description?: string;
  class?: string;
}

const {
  title = '',
  description = '',
  class: className = ''
} = Astro.props
---

<Grid Tag="section" class:list={["py-xlg", className]} >
  { title ? (
    <Text variant="tlg" Tag="h2" class={`col-span-full${description ? ' mb-sm' : ' mb-md md:mb-lg'}`}>{title}</Text>
  ) : null}
  { description ? (
    <Text variant="pmd" class="col-span-full max-w-[55rem] mb-md md:mb-lg">{description}</Text>
  ) : null}
  <slot />
</Grid>
