---
import Text from "@components/atoms/text.astro"
import Grid from "@components/organisms/grid.astro"

export interface Props {
	title?: string
}

const { title = "" } = Astro.props
---

<Grid Tag="header" class="pt-[43rem] pb-[2rem] items-end">
	<Text variant="txlg" class="col-span-full mb-sm md:mb-0 md:mt-sm md:order-2">
		{title}
	</Text>
</Grid>
