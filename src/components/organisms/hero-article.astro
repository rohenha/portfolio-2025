---
import { formatDate } from "@utils/helpers"
// Components
import Text from "@components/atoms/text.astro"
import Tag from "@components/atoms/tag.astro"

export interface Props {
	title?: string
	date: Date
	tags: Array<string>
}

const { title = "", date, tags } = Astro.props
---

<header class="mb-lg items-end">
	<Text variant="tlg" class="mb-xsm">
		{title}
	</Text>
	<ul class="flex flex-row gap-x-tiny items-center">
		<Text variant="tagalt" Tag="li">
			{formatDate(date)}
		</Text>
		{
			tags.map((tag) => (
				<Tag variant="gray-500" class="shrink-0" tag="li">
					{tag}
				</Tag>
			))
		}
	</ul>
</header>
