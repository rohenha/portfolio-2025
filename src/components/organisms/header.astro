---
// Content
import nav from '@content/nav'
// Tools
import { formatLink } from '@utils/helpers'
// Components
import Button from '@components/atoms/button.astro'

const currentPath = Astro.url.pathname
---

<header class="fixed top-0 left-[50%] w-full translate-x-[-50%] py-md px-sm md:px-xlg max-w-[140rem] mx-auto flex">
    <nav class="ml-auto">
      <ul role="list" class="flex flex-row gap-sm items-center">
        <li class="relative -top-px">
          <a href="/" class="flex flex-row font-serif text-btn uppercase tracking-md font-700 gap-0 hover:text-green-700">R<span class="sr-only">omain</span> B<span class="sr-only">reton</span></a>
        </li>
        {nav.header.map(item => (
          <li><Button attributes={formatLink(item)} href={item.url} variant="nav-alt-gray-900" class={currentPath === item.url ? ' -active' : ''}>{item.name}</Button></li>
        ))}
      </ul>
    </nav>
</header>