---
export interface Props {
	// Si true, affiche une barre de progression indiquant la position de l'utilisateur dans la page
	class?: string
	attributes?: Record<string, string>
}

const { class: className = "", attributes = {} } = Astro.props
---

<svg
	class:list={[
		"a-progress w-[1.8rem] h-[1.8rem] bg-gray-900 rounded-full p-[0.3rem]",
		className,
	]}
	{...attributes}
>
	<circle
		cx="50%"
		cy="50%"
		r="43%"
		stroke-width="0.2rem"
		stroke="#fff"
		fill="transparent"
		style="stroke-dasharray: 33; stroke-dashoffset: 33;"
		data-module-experience="experience"
		class="-rotate-90 origin-center"
	>
	</circle>
</svg>
