---
const variants = {
  thuge: 'text-thuge font-serif tracking-md md:text-txhuge whitespace-nowrap',
  txlg: 'text-txlg font-serif tracking-md',
  tmd: 'text-tmd font-serif tracking-md',
  tsm: 'text-tsm font-serif tracking-sm ',
  quote: 'text-quote font-serif',
  pmd: 'text-pmd tracking-sm',
  amd: 'text-pmd font-serif tracking-md',
  bmd: 'text-btn tracking-sm',
  tag: 'text-tag tracking-md',
  tagalt: 'text-tag font-serif tracking-md',
  input: 'text-input font-serif tracking-sm',
}

export interface Props {
  Tag?: keyof HTMLElementTagNameMap;
  attributes?: Record<string, string>;
  variant?: keyof typeof variants;
  class?: string;
}

const { 
  Tag = 'p', 
  variant= "thuge", 
  attributes = {},
  class: className
} = Astro.props

---


<Tag class:list={[variants[variant], className]} {...attributes}><slot/></Tag>