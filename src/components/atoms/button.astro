---
import Text from "@components/atoms/text.astro"

export const variants = {
  'primary-gray-900' : 'bg-gray-900 text-gray-300 rounded-sm px-[1.2rem] py-[0.7rem]',
  'primary-green-700' : 'bg-green-700 text-gray-300 rounded-sm px-[1.2rem] py-[0.7rem]',
  'primary-gray-300' : 'bg-gray-300 text-gray-900 rounded-sm px-[1.2rem] py-[0.7rem]',
  'secondary-gray-900' : 'btn-secondary text-gray-300 rounded-sm px-[0.2rem] py-[0.3rem] hover:bg-gray-300 hover:text-gray-900',
  'secondary-gray-300' : 'btn-secondary text-gray-900 rounded-sm px-[0.2rem] py-[0.3rem] hover:bg-gray-900 hover:text-gray-300',
}
export interface Props {
  icon?: string;
  variant?: keyof typeof variants;
  attributes?: Record<string, string>;
  url?: string;
  tag?: keyof HTMLElementTagNameMap;
  class?: string;
}

const {
  variant = 'primary-gray-900',
  attributes = {},
  url,
  class: className
} = Astro.props;

let { 
  icon,
  tag = 'button',
} = Astro.props;

// Remove icon for non-primary variants
if (!variant.startsWith('primary')) {
  icon = ''
}

const list = [variants[variant], className]


// Icons btn-icon-arrow
if (icon) {
  list.push('btn-icon-' + icon)
}

// add href attribute if needed
if (url) {
  attributes.href = url
  tag = 'a'
}
---

<Text class:list={list} variant="bmd" Tag={tag} attributes={attributes}><slot/></Text>
