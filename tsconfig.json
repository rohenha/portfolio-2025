{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist", "node_modules"],
	"compilerOptions": {
		"baseUrl": ".",
		"moduleResolution": "Bundler",
		"declaration": true,
		"declarationDir": "./types",
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"paths": {
			"@layouts/*": ["./src/layouts/*"],
			"@components/*": ["./src/components/*"],
			"@assets/*": ["./src/assets/*"],
			"@styles/*": ["./src/styles/*"],
			"@content/*": ["./content/*"],
			"@utils/*": ["./utils/*"],
			"@config/*": ["./config/*"],
			"@images/*": ["./src/images/*"],
			"@js/*": ["./src/js/*"]
		}
	}
}
